# Windows MAX_PATH (260) mitigation: pnpm's default .pnpm virtual-store
# directory names embed the full peer-dependency hash and, combined with a
# deep worktree path, overflow Node's package.json (#imports) resolution on
# Windows. Shortening the virtual-store dir names keeps the isolated linker
# semantics identical while keeping paths well under the limit. No effect on
# Linux/CI behavior.
virtual-store-dir-max-length=24
